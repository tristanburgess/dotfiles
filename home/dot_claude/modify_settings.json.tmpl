{{- /* Normalize home dir to forward slashes — Windows uses backslashes
       which would be invalid inside JSON strings if not escaped. */ -}}
{{- $home := replace "\\" "/" .chezmoi.homeDir -}}
#!/bin/bash
# Merge chezmoi-managed keys into the live settings.json, preserving
# any runtime additions (plugins, marketplaces, etc.) that Claude Code
# writes at runtime.
#
# chezmoi pipes the current target file contents to stdin.
# We output the merged result to stdout.

# Statusline path differs by OS — `~` expansion is unreliable on Windows
# because Claude Code launches the command in its own shell, not Git Bash.
{{- if eq .chezmoi.os "windows" }}
STATUSLINE_CMD='bun "{{ $home }}/.claude/statusline-command.js"'
{{- else }}
STATUSLINE_CMD='bun ~/.claude/statusline-command.js'
{{- end }}

# Guard: if jq isn't installed yet, pass through the current file unchanged.
if ! command -v jq >/dev/null 2>&1; then
  cat
  exit 0
fi

MANAGED='
{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Bash(bun*)",
      "Bash(cat*)",
      "Bash(chezmoi diff*)",
      "Bash(chezmoi status*)",
      "Bash(eslint*)",
      "Bash(find*)",
      "Bash(gh api*)",
      "Bash(gh pr*)",
      "Bash(go build*)",
      "Bash(go doc*)",
      "Bash(go env*)",
      "Bash(go run*)",
      "Bash(go test*)",
      "Bash(go vet*)",
      "Bash(grep*)",
      "Bash(jj*)",
      "Bash(ls*)",
      "Bash(make *)",
      "Bash(make)",
      "Bash(mise*)",
      "Bash(mypy*)",
      "Bash(node*)",
      "Bash(npm list*)",
      "Bash(npm outdated*)",
      "Bash(npm run*)",
      "Bash(npm test*)",
      "Bash(npx*)",
      "Bash(pip freeze*)",
      "Bash(pip list*)",
      "Bash(pip show*)",
      "Bash(pytest*)",
      "Bash(python*)",
      "Bash(ruff check*)",
      "Bash(ruff format*)",
      "Bash(sed*)",
      "Bash(tsc*)",
      "Bash(which*)"
    ],
    "deny": [
      "Read({{ $home }}/.ssh/**)",
      "Read({{ $home }}/.aws/**)",
      "Read(**/.env*)",
      "Read(**/credentials*)",
      "Edit({{ $home }}/.ssh/**)",
      "Edit({{ $home }}/.aws/**)",
      "Edit(**/.env*)",
      "Write({{ $home }}/.ssh/**)",
      "Write({{ $home }}/.aws/**)",
      "Write(**/.env*)",
      "Bash(curl*|*bash*)",
      "Bash(ssh *)",
      "Bash(nc *)",
      "Bash(scp *)",
      "Bash(rm -rf /)",
      "Bash(chmod 777*)",
      "Bash(*--force*push*)",
      "Bash(*--no-verify*)"
    ]
  },
  "model": "opus[1m]",
  "effortLevel": "high",
  "includeCoAuthoredBy": false,
  "gitAttribution": false,
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku"
  },
  "statusLine": {
    "type": "command",
    "command": ""
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/config-protection.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/block-no-verify.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/bash-audit-log.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-color.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/notify.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/verify-nudge.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/notify.sh"
          }
        ]
      }
    ]
  }
}
'

# Inject statusline command (OS-dependent path)
MANAGED=$(echo "$MANAGED" | jq --arg sl "$STATUSLINE_CMD" '.statusLine.command = $sl')

CURRENT=$(cat)

if [ -z "$CURRENT" ] || [ "$CURRENT" = "{}" ]; then
  echo "$MANAGED" | jq .
  exit 0
fi

# Recursive merge: start with current (preserves runtime keys),
# then overlay managed keys on top (managed always wins).
echo "$CURRENT" | jq --argjson managed "$MANAGED" '. * $managed'
