{{- /* Normalize home dir to forward slashes — Windows uses backslashes
       which would be invalid inside JSON strings if not escaped. */ -}}
{{- $home := replace "\\" "/" .chezmoi.homeDir -}}
#!/bin/bash
# Merge chezmoi-managed keys into the live settings.json, preserving
# any runtime additions (plugins, marketplaces, etc.) that Claude Code
# writes at runtime.
#
# chezmoi pipes the current target file contents to stdin.
# We output the merged result to stdout.

{{- if eq .chezmoi.os "windows" }}
# Refresh PATH from Windows registry — winget installs (like jq) add PATH
# entries that the current Git Bash session doesn't see yet.
# Read the registry PATH (semicolon-delimited, backslash Windows paths) and
# convert to Git Bash format (colon-delimited, /c/... Unix paths).
FRESH_PATH=$(powershell.exe -NoProfile -Command \
    '[Environment]::GetEnvironmentVariable("Path","Machine") + ";" + [Environment]::GetEnvironmentVariable("Path","User")' \
    2>/dev/null | tr -d '\r' | tr ';' '\n' | sed 's|\\|/|g; s|^\([A-Za-z]\):|/\L\1|' | paste -sd:)
[ -n "$FRESH_PATH" ] && export PATH="$FRESH_PATH:$PATH"
{{- end }}

# Statusline path differs by OS — `~` expansion is unreliable on Windows
# because Claude Code launches the command in its own shell, not Git Bash.
{{- if eq .chezmoi.os "windows" }}
STATUSLINE_CMD='bun "{{ $home }}/.claude/statusline-command.js"'
{{- else }}
STATUSLINE_CMD='bun ~/.claude/statusline-command.js'
{{- end }}

# Guard: if jq isn't installed yet, pass through the current file unchanged.
if ! command -v jq >/dev/null 2>&1; then
  cat
  exit 0
fi

MANAGED='
{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Bash(bun*)",
      "Bash(cat*)",
      "Bash(chezmoi diff*)",
      "Bash(chezmoi status*)",
      "Bash(eslint*)",
      "Bash(find*)",
      "Bash(gh api*)",
      "Bash(gh pr*)",
      "Bash(go build*)",
      "Bash(golangci-lint*)",
      "Bash(go doc*)",
      "Bash(go env*)",
      "Bash(go run*)",
      "Bash(go test*)",
      "Bash(go vet*)",
      "Bash(grep*)",
      "Bash(jj*)",
      "Bash(ls*)",
      "Bash(make *)",
      "Bash(make)",
      "Bash(mise*)",
      "Bash(mypy*)",
      "Bash(node*)",
      "Bash(npm list*)",
      "Bash(npm outdated*)",
      "Bash(npm run*)",
      "Bash(npm test*)",
      "Bash(npx*)",
      "Bash(pip freeze*)",
      "Bash(pip list*)",
      "Bash(pip show*)",
      "Bash(pytest*)",
      "Bash(python*)",
      "Bash(ruff check*)",
      "Bash(ruff format*)",
      "Bash(sed*)",
      "Bash(tsc*)",
      "Bash(which*)"
    ],
    "deny": [
      "Read({{ $home }}/.ssh/**)",
      "Read({{ $home }}/.aws/**)",
      "Read(**/.env*)",
      "Read(**/credentials*)",
      "Edit({{ $home }}/.ssh/**)",
      "Edit({{ $home }}/.aws/**)",
      "Edit(**/.env*)",
      "Write({{ $home }}/.ssh/**)",
      "Write({{ $home }}/.aws/**)",
      "Write(**/.env*)",
      "Bash(bash *)",
      "Bash(sh *)",
      "Bash(ssh *)",
      "Bash(nc *)",
      "Bash(scp *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(jj git push --force*)",
      "Bash(git commit*--no-verify*)",
      "Bash(git rebase*--no-verify*)",
      "Bash(git merge*--no-verify*)",
      "Bash(jj*--no-verify*)",
      "Bash(gh*--no-verify*)",
      "Bash(pre-commit*--no-verify*)"
    ]
  },
  "model": "sonnet[1m]",
  "effortLevel": "high",
  "includeCoAuthoredBy": false,
  "gitAttribution": false,
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku",
    "CLAUDE_MONTHLY_BUDGET": "200"{{ if (get . "useCcr" | default true) }},
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:3456"{{ end }}
  },
  "mcpServers": {
    "duckduckgo": {
      "command": "{{ $home }}/.local/share/mise/shims/duckduckgo-mcp-server",
      "args": []
    }
  },
  "statusLine": {
    "type": "command",
    "command": ""
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "caveman@caveman": true,
    "prose-craft@prose-craft": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "prose-craft": {
      "source": {
        "source": "github",
        "repo": "tristanburgess/prose-craft"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/config-protection.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/block-no-verify.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/go-format-lint.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/bash-audit-log.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-color.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/notify.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/verify-nudge.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/notify.sh"
          }
        ]
      }
    ]
  }
}
'

# Inject statusline command (OS-dependent path)
MANAGED=$(echo "$MANAGED" | jq --arg sl "$STATUSLINE_CMD" '.statusLine.command = $sl')

CURRENT=$(cat)

# Empty / whitespace-only / `{}` (with any whitespace) → emit managed shape.
# `jq -e 'length == 0'` returns true for an empty object regardless of
# formatting; `2>/dev/null` covers the empty-string case where jq would
# otherwise error.
if [ -z "$CURRENT" ] || jq -e 'length == 0' >/dev/null 2>&1 <<< "$CURRENT"; then
  echo "$MANAGED" | jq .
  exit 0
fi

# Recursive merge: start with current (preserves runtime keys),
# then overlay managed keys on top (managed always wins).
# For env specifically: managed provides defaults, then local env is
# overlaid on top so local overrides and additions are preserved.
echo "$CURRENT" | jq --argjson managed "$MANAGED" '
  . as $current
  | . * $managed
  | .env = ($managed.env * ($current.env // {}))
  | .mcpServers = ($managed.mcpServers * ($current.mcpServers // {}))
'
