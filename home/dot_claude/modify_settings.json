#!/bin/bash
# Merge chezmoi-managed keys into the live settings.json, preserving
# any runtime additions (plugins, marketplaces, etc.) that Claude Code
# writes at runtime.
#
# chezmoi pipes the current target file contents to stdin.
# We output the merged result to stdout.

MANAGED='
{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Bash(bun*)",
      "Bash(cat*)",
      "Bash(chezmoi diff*)",
      "Bash(chezmoi status*)",
      "Bash(eslint*)",
      "Bash(find*)",
      "Bash(gh api*)",
      "Bash(gh pr*)",
      "Bash(go build*)",
      "Bash(go doc*)",
      "Bash(go env*)",
      "Bash(go run*)",
      "Bash(go test*)",
      "Bash(go vet*)",
      "Bash(grep*)",
      "Bash(jj*)",
      "Bash(ls*)",
      "Bash(make *)",
      "Bash(make)",
      "Bash(mise*)",
      "Bash(mypy*)",
      "Bash(node*)",
      "Bash(npm list*)",
      "Bash(npm outdated*)",
      "Bash(npm run*)",
      "Bash(npm test*)",
      "Bash(npx*)",
      "Bash(pip freeze*)",
      "Bash(pip list*)",
      "Bash(pip show*)",
      "Bash(pytest*)",
      "Bash(python*)",
      "Bash(ruff check*)",
      "Bash(ruff format*)",
      "Bash(sed*)",
      "Bash(tsc*)",
      "Bash(which*)"
    ],
    "deny": [
      "Read(/home/tristan/.ssh/**)",
      "Read(/home/tristan/.aws/**)",
      "Read(**/.env*)",
      "Read(**/credentials*)",
      "Edit(/home/tristan/.ssh/**)",
      "Edit(/home/tristan/.aws/**)",
      "Edit(**/.env*)",
      "Write(/home/tristan/.ssh/**)",
      "Write(/home/tristan/.aws/**)",
      "Write(**/.env*)",
      "Bash(curl*|*bash*)",
      "Bash(ssh *)",
      "Bash(nc *)",
      "Bash(scp *)",
      "Bash(rm -rf /)",
      "Bash(chmod 777*)",
      "Bash(*--force*push*)",
      "Bash(*--no-verify*)"
    ]
  },
  "model": "opus[1m]",
  "effortLevel": "high",
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "haiku"
  },
  "statusLine": {
    "type": "command",
    "command": "bun ~/.claude/statusline-command.js"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "tristanburgess/caveman"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/config-protection.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/block-no-verify.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/bash-audit-log.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-color.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/notify.sh"
          },
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/verify-nudge.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/notify.sh"
          }
        ]
      }
    ]
  }
}
'

CURRENT=$(cat)

if [ -z "$CURRENT" ] || [ "$CURRENT" = "{}" ]; then
  echo "$MANAGED" | jq .
  exit 0
fi

# Recursive merge: start with current (preserves runtime keys),
# then overlay managed keys on top (managed always wins).
echo "$CURRENT" | jq --argjson managed "$MANAGED" '. * $managed'
