#!/bin/bash
# Merge chezmoi-managed keys into the live settings.json, preserving
# any runtime additions (plugins, marketplaces, etc.) that Claude Code
# writes at runtime.
#
# chezmoi pipes the current target file contents to stdin.
# We output the merged result to stdout.

MANAGED='
{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Read",
      "Bash(gh api*)",
      "Bash(gh pr*)",
      "Bash(jj*)",
      "Bash(go vet*)",
      "Bash(go doc*)",
      "Bash(go env*)",
      "Bash(find*)",
      "Bash(grep*)",
      "Bash(sed*)"
    ]
  },
  "model": "opus[1m]",
  "effortLevel": "high",
  "statusLine": {
    "type": "command",
    "command": "bun ~/.claude/statusline-command.js"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-color.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/notify.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/notify.sh"
          }
        ]
      }
    ]
  }
}
'

CURRENT=$(cat)

if [ -z "$CURRENT" ] || [ "$CURRENT" = "{}" ]; then
  echo "$MANAGED" | jq .
  exit 0
fi

# Recursive merge: start with current (preserves runtime keys),
# then overlay managed keys on top (managed always wins).
echo "$CURRENT" | jq --argjson managed "$MANAGED" '. * $managed'
