# Files managed by run scripts or created at runtime
.claude/claude-logo.png
.claude/budget-tracker.json
.claude/projects/**
.claude/memory/**
.claude/todos/**
.claude/plans/**

{{- /* Re-derive isWSL here because .chezmoiignore is rendered before .chezmoi.toml.tmpl
       data is exposed in some chezmoi versions; safer to be self-contained. */ -}}
{{- $isWSL := false -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   $osr := .chezmoi.kernel.osrelease | default "" | lower -}}
{{-   if or (contains "microsoft" $osr) (contains "wsl" $osr) -}}
{{-     $isWSL = true -}}
{{-   end -}}
{{- end }}

{{ if eq .chezmoi.os "windows" }}
# ─── Windows-native: hide everything Linux-only ───
# (.chezmoiscripts/* entries are gated via body-wrapped .tmpl files instead,
#  because .chezmoiignore matches target paths and scripts have no target.)
# Patterns are TARGET paths (post-`dot_` and `executable_` rewrites).
.config/kitty/**
.config/gcloud/**
.config/Code/**
{{ end }}

{{ if ne .chezmoi.os "windows" }}
# ─── Linux/WSL: hide Windows-AppData-only files ───
AppData/**
{{ end }}

{{ if ne .chezmoi.os "windows" }}
# ─── Linux/WSL: hide Windows-only target files ───
.minttyrc
.bashrc
.wslconfig
{{ end }}

{{ if and (eq .chezmoi.os "linux") $isWSL }}
# ─── WSL: hide bare-metal-only target files that fail in WSLg ───
# Notion/Calibre-bound skills only run where Notion Desktop + Calibre live
# (bare-metal Linux + Windows host). WSL has neither.
.claude/skills/guitar-tutor/**
.claude/skills/health/**
{{ end }}

{{ if not (get . "installClaude" | default true) }}
# ─── User opted out of Claude at init time ───
.claude/**
{{ end }}

{{ if not (get . "installCodex" | default false) }}
# ─── User opted out of Codex at init time ───
.codex/**
{{ end }}

{{ if not (get . "useCcr" | default true) }}
# ─── User opted out of tiered model routing (no CCR + Ollama) ───
.claude-code-router/**
.config/systemd/user/claude-code-router.service
{{ end }}
