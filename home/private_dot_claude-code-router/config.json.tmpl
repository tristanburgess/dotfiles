{
  "LOG": false,
  "LOG_LEVEL": "warn",
  "HOST": "127.0.0.1",
  "PORT": 3456,
  "API_TIMEOUT_MS": 600000,
  "CUSTOM_ROUTER_PATH": "{{ .chezmoi.homeDir }}/.claude-code-router/router.js",
  "transformers": [
    {
      "path": "{{ .chezmoi.homeDir }}/.claude-code-router/cloudfallback.transformer.js"
    }
  ],
  "Providers": [
    {
      "name": "anthropic",
      "api_base_url": "https://api.anthropic.com/v1/messages",
      "api_key": "$ANTHROPIC_API_KEY",
      "models": [
        "{{ .cloud.opus }}",
        "{{ .cloud.opus }}[1m]",
        "{{ .cloud.sonnet }}",
        "{{ .cloud.sonnet }}[1m]",
        "{{ .cloud.haiku }}",
        "sonnet",
        "sonnet[1m]",
        "opus",
        "opus[1m]",
        "haiku"
      ],
      "transformer": {
        "use": ["Anthropic", "cloudfallback"]
      }
    },
    {
      "name": "ollama",
      "api_base_url": "http://localhost:11434/v1/chat/completions",
      "api_key": "ollama",
      "models": [
        "{{ .ollama.code }}",
        "{{ .ollama.prose }}",
        "{{ .ollama.think }}"
      ]
    }
  ],
  "Router": {
    "default":     "anthropic,{{ .cloud.sonnet }}",
    "background":  "ollama,{{ .ollama.code }}",
    "think":       "ollama,{{ .ollama.think }}",
    "longContext": "anthropic,{{ .cloud.sonnet }}",
    "longContextThreshold": 60000,
    "webSearch":   "anthropic,{{ .cloud.sonnet }}"
  }
}
