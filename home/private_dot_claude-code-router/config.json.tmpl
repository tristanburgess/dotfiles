{
  "LOG": false,
  "LOG_LEVEL": "warn",
  "HOST": "127.0.0.1",
  "PORT": 3456,
  "API_TIMEOUT_MS": 600000,
  "CUSTOM_ROUTER_PATH": "{{ .chezmoi.homeDir }}/.claude-code-router/router.js",
  "transformers": [
    {
      "path": "{{ .chezmoi.homeDir }}/.claude-code-router/cloudfallback.transformer.js"
    },
    {
      "path": "{{ .chezmoi.homeDir }}/.claude-code-router/anthropic-shim.transformer.js"
    },
    {
      "path": "{{ .chezmoi.homeDir }}/.claude-code-router/audit.transformer.js"
    }
  ],
  "Providers": [
    {
      "name": "anthropic",
      {{- if eq (get . "cloudAuth" | default "apikey") "ccs-pro" }}
      "api_base_url": "http://127.0.0.1:8317/v1/chat/completions",
      "api_key": "ccs-internal-managed",
      {{- else }}
      "api_base_url": "https://api.anthropic.com/v1/messages",
      "api_key": "$ANTHROPIC_API_KEY",
      {{- end }}
      "models": [
        "{{ .cloud.opus }}",
        "{{ .cloud.opus }}[1m]",
        "{{ .cloud.sonnet }}",
        "{{ .cloud.sonnet }}[1m]",
        "{{ .cloud.haiku }}",
        "sonnet",
        "sonnet[1m]",
        "opus",
        "opus[1m]",
        "haiku"
      ],
      {{- if ne (get . "cloudAuth" | default "apikey") "ccs-pro" }}
      "transformer": {
        "use": ["Anthropic"]
      }
      {{- end }}
    },
    {
      "name": "local",
      "api_base_url": "http://127.0.0.1:11434/v1/chat/completions",
      "api_key": "local",
      "models": [
        "{{ .local.code }}",
        "{{ .local.prose }}",
        "{{ .local.think }}"
      ]
    }
  ],
  "Router": {
    "default":     "anthropic,{{ .cloud.sonnet }}",
    "background":  "local,{{ .local.code }}",
    "think":       "local,{{ .local.think }}",
    "longContext": "anthropic,{{ .cloud.sonnet }}",
    "longContextThreshold": 60000,
    "webSearch":   "anthropic,{{ .cloud.sonnet }}"
  },
  "fallback": {
    "default": ["local,{{ .local.code }}"]
  }
}
