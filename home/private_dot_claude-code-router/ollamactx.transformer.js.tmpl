// CCR custom transformer: inject options.num_ctx into Ollama-bound requests.
//
// Per Ollama API docs, request-level options have highest precedence over:
//   - Modelfile PARAMETER num_ctx (used by our derived `<base>-ctx<N>k` tags)
//   - OLLAMA_CONTEXT_LENGTH env var (Windows desktop GUI sets this, defaults
//     to 4K on the slider, silently truncating the Modelfile setting)
//
// Wired in via config.json:
//   transformers: [{ path: ".../ollamactx.transformer.js" }]
//   Providers[ollama].transformer.use: ["ollamactx"]
//
// num_ctx is templated at chezmoi-apply time from .ollamaNumCtx (computed
// per-profile from total RAM). Bump the value by editing chezmoi.toml then
// `chezmoi apply` (which also rebuilds the derived Modelfile tags).

const NUM_CTX = {{ .ollamaNumCtx }};

class OllamaCtxTransformer {
  constructor(options) {
    this.options = options || {};
    this.name = "ollamactx";
  }

  async transformRequestIn(request /*, provider, ctx */) {
    if (!request) return request;

    // Ollama's /v1/chat/completions OpenAI shim accepts an `options` object
    // as a passthrough to the native /api/chat options. Only set the nested
    // form. Top-level num_ctx is non-standard and risks shim rejection.
    request.options = request.options || {};
    if (request.options.num_ctx == null) {
      request.options.num_ctx = NUM_CTX;
    }
    if (process.env.CCR_DEBUG_OLLAMACTX === "1") {
      console.log(`[ollamactx] num_ctx=${request.options.num_ctx} model=${request.model || "?"} keys=${Object.keys(request).join(",")}`);
    }
    return request;
  }
}

OllamaCtxTransformer.TransformerName = "ollamactx";

module.exports = OllamaCtxTransformer;
