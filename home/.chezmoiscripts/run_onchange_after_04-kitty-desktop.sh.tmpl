{{- if .isLinuxBaremetal -}}
#!/bin/bash
# hash: {{ include ".chezmoiscripts/run_onchange_after_01-kitty-install.sh.tmpl" | sha256sum }}
set -euo pipefail

# Patch kitty .desktop files so GNOME can find the kitty install.
# Bare-metal Linux only — WSLg auto-registers kitty.desktop, no patching needed.

KITTY_INSTALL="$HOME/.local/kitty.app"
KITTY_SHIM="$HOME/.local/bin/kitty"

mkdir -p "$HOME/.local/share/applications"
for desktop in kitty.desktop kitty-open.desktop; do
    src="$KITTY_INSTALL/share/applications/$desktop"
    [ -f "$src" ] || continue
    dest="$HOME/.local/share/applications/$desktop"
    cp "$src" "$dest"
    sed -i "s|^Icon=kitty|Icon=$KITTY_INSTALL/share/icons/hicolor/256x256/apps/kitty.png|" "$dest"
    sed -i "s|^Exec=kitty|Exec=$KITTY_SHIM|" "$dest"
    sed -i "s|^TryExec=kitty|TryExec=$KITTY_SHIM|" "$dest"
done
{{- end -}}
