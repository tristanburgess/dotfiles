{{- if and .isLinuxBaremetal .installClaude (get . "useCcr" | default true) -}}
#!/bin/bash
set -euo pipefail

# Enable the claude-code-router systemd user service. Re-runs when this
# script or the unit changes.

UNIT_NAME=claude-code-router.service

# daemon-reload is required when the unit file content changes.
systemctl --user daemon-reload

if ! systemctl --user is-enabled --quiet "$UNIT_NAME"; then
    systemctl --user enable "$UNIT_NAME"
fi

if ! systemctl --user is-active --quiet "$UNIT_NAME"; then
    systemctl --user start "$UNIT_NAME" || {
        printf "Failed to start %s — check 'journalctl --user -u %s'.\n" \
            "$UNIT_NAME" "$UNIT_NAME"
        exit 1
    }
else
    # If the unit already running, restart so config/router.js changes apply.
    systemctl --user restart "$UNIT_NAME"
fi

printf "claude-code-router service active.\n"
{{- else if and .isLinuxBaremetal .installClaude -}}
#!/bin/bash
set -euo pipefail

# useCcr=false teardown for the ccr user service. Re-runs when the
# rendered script content changes (i.e., when the flag flips from true
# → false). The unit file itself is removed by .chezmoiignore.

UNIT_NAME=claude-code-router.service

if systemctl --user is-active --quiet "$UNIT_NAME" 2>/dev/null; then
    systemctl --user stop "$UNIT_NAME" || true
fi
if systemctl --user is-enabled --quiet "$UNIT_NAME" 2>/dev/null; then
    systemctl --user disable "$UNIT_NAME" || true
fi

systemctl --user daemon-reload || true

printf "claude-code-router service stopped and disabled.\n"
{{- end -}}
