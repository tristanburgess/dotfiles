{{- if eq .chezmoi.os "windows" -}}
# Windows-only winget installer.
# chezmoi runs .ps1 natively on Windows via PowerShell -- no [interpreters] needed.
# Body-wrapped so this file is a no-op on Linux/macOS.
$ErrorActionPreference = 'Continue'  # tolerate individual package failures

# Bootstrap dependencies (needed before mise can run)
$bootstrap = @(
    'Microsoft.PowerShell',             # Update to latest
    'Git.Git',                          # Git for Windows (provides Git Bash)
    'twpayne.chezmoi',                  # chezmoi itself (idempotent)
    'jdx.mise'                          # mise tool manager
)

# Cloud CLIs live in WSL only (mise-managed). Windows host stays thin.
$cloudCLIs = @()

# Local LLM runtime -- Windows host owns the GPU and the model store.
# WSL clients hit http://localhost:11434 via mirrored networking.
$llmRuntime = @(
    'Ollama.Ollama'
)

# Desktop apps -- Windows-native equivalents of Linux snap/deb packages
$desktopApps = @(
    'Anthropic.Claude',                 # Claude Desktop (replaces .deb on Linux)
    'Microsoft.VisualStudioCode',       # VS Code on host; drives WSL via Remote-WSL extension
    'SlackTechnologies.Slack',
    'Spotify.Spotify',
    'Notion.Notion',
    'Discord.Discord',
    'Zoom.Zoom',
    'calibre.calibre'                    # e-reader (Calibre on both Windows and Linux)
)
# PDF tooling
$pdfTools = @(
    'QPDF.QPDF',                        # qpdf -- PDF splitter/repair/linearize
    'tesseract-ocr.tesseract'           # tesseract -- OCR engine (ocrmypdf runs via uvx)
)

# Dev tools -- cross-platform equivalents of Linux-side installs
$devTools = @(
    'CoreyButler.NVMforWindows'         # nvm-windows -- mirrors nvm on Linux
)

# Image processing -- consolidated to Windows host (removed from Linux apt).
$imageTools = @(
    'ImageMagick.ImageMagick'           # imagemagick -- convert/identify/montage/etc.
)

# DND keybinding runtime -- AHK fires ~/bin/toggle-dnd.sh on Win+Shift+D.
$dndTools = @(
    'AutoHotkey.AutoHotkey'             # global hotkey daemon for DND toggle
)

# Map winget IDs to process names for apps that block installs while running
$processNames = @{
    'Spotify.Spotify'              = @('Spotify', 'SpotifyLauncher')
    'SlackTechnologies.Slack'      = 'slack'
    'Discord.Discord'              = 'Discord'
    'Zoom.Zoom'                    = 'Zoom'
    'Notion.Notion'                = 'Notion'
    'Anthropic.Claude'             = 'Claude'
    'Microsoft.VisualStudioCode'   = 'Code'
}

# Packages that can't be upgraded while chezmoi apply is running.
# Git.Git: Git Bash is the shell running chezmoi -- upgrading kills the session.
# twpayne.chezmoi: chezmoi.exe is locked by the running process.
$skipUpgrade = @('Git.Git', 'twpayne.chezmoi')
$deferredUpgrades = @()

function Close-AppIfRunning($pkg) {
    if (-not $processNames.ContainsKey($pkg)) { return $true }
    $names = @($processNames[$pkg])
    $proc = Get-Process -Name $names -ErrorAction SilentlyContinue
    if (-not $proc) { return $true }
    $running = ($proc | Select-Object -ExpandProperty Name -Unique) -join ', '
    $answer = Read-Host "$running is running and must be closed to install/update $pkg. Close it? (y/n)"
    if ($answer -eq 'y') {
        $proc | Stop-Process -Force
        Start-Sleep -Seconds 2
        return $true
    }
    return $false
}

$packages = $bootstrap + $cloudCLIs + $llmRuntime + $desktopApps + $pdfTools + $devTools + $imageTools + $dndTools

foreach ($pkg in $packages) {
    $installed = winget list --id $pkg --exact 2>$null | Select-String $pkg
    if (-not $installed) {
        # New install
        if (-not (Close-AppIfRunning $pkg)) {
            Write-Host "Skipping $pkg (app still running)"
            continue
        }
        Write-Host "Installing $pkg..."
        try {
            winget install --exact --id $pkg `
                --accept-package-agreements `
                --accept-source-agreements --silent
        } catch {
            Write-Warning "Failed to install ${pkg}: $_"
        }
    } else {
        # Check for available upgrade
        $upgrade = winget upgrade --id $pkg --exact 2>$null | Select-String $pkg
        if ($upgrade) {
            if ($pkg -in $skipUpgrade) {
                Write-Host "$pkg upgrade available but cannot upgrade during chezmoi apply (file locked)"
                $deferredUpgrades += $pkg
                continue
            }
            if (-not (Close-AppIfRunning $pkg)) {
                Write-Host "Skipping upgrade of $pkg (app still running)"
                continue
            }
            Write-Host "Upgrading $pkg..."
            try {
                winget upgrade --exact --id $pkg `
                    --accept-package-agreements `
                    --accept-source-agreements --silent
            } catch {
                Write-Warning "Failed to upgrade ${pkg}: $_"
            }
        } else {
            Write-Host "$pkg up to date"
        }
    }
}

if ($deferredUpgrades.Count -gt 0) {
    Write-Host ""
    Write-Host "=== Deferred upgrades (run manually after closing Git Bash) ==="
    foreach ($pkg in $deferredUpgrades) {
        Write-Host "  winget upgrade --exact --id $pkg"
    }
}

{{ if get . "enableOllamaLan" | default false }}
# ── Ollama LAN exposure ──────────────────────────────────────────────────
# Bind Ollama to all interfaces, allow inbound on Private profile from the
# local subnet only. Untrusted networks (Public profile) stay blocked.
$ollamaEnv = @{
    OLLAMA_HOST    = '0.0.0.0:11434'
    OLLAMA_ORIGINS = '*'
}
$envChanged = $false
foreach ($kv in $ollamaEnv.GetEnumerator()) {
    $cur = [Environment]::GetEnvironmentVariable($kv.Key, 'Machine')
    if ($cur -ne $kv.Value) {
        [Environment]::SetEnvironmentVariable($kv.Key, $kv.Value, 'Machine')
        Write-Host "Set machine env $($kv.Key)=$($kv.Value)"
        $envChanged = $true
    }
}

if (-not (Get-NetFirewallRule -Name 'Ollama-LAN' -ErrorAction SilentlyContinue)) {
    New-NetFirewallRule -Name 'Ollama-LAN' -DisplayName 'Ollama LAN (TCP 11434)' `
        -Direction Inbound -Action Allow -Protocol TCP -LocalPort 11434 `
        -Profile Private -RemoteAddress LocalSubnet | Out-Null
    Write-Host "Created firewall rule Ollama-LAN (Private, LocalSubnet)"
}

if ($envChanged) {
    $svc = Get-Service Ollama -ErrorAction SilentlyContinue
    if ($svc -and $svc.Status -eq 'Running') {
        Write-Host "Restarting Ollama service to pick up new bind address"
        Restart-Service Ollama
    }
}
{{ end }}

# ── VS Code extensions ───────────────────────────────────────────────────
# Host-side extensions only (UI scope). Workspace-scope extensions for code
# living in WSL (Go, Rust on Linux) are installed inside WSL by
# run_onchange_after_07-vscode-extensions.sh.tmpl. Rust pack here is for
# energybeam -- the native Windows Rust project on the host.
$codeExtensions = @(
    'ms-vscode-remote.remote-wsl',
    'rust-lang.rust-analyzer',          # official LSP
    'vadimcn.vscode-lldb',              # CodeLLDB -- debugger for native Rust
    'tamasfe.even-better-toml',         # Cargo.toml syntax + schema
    'fill-labs.dependi',                # Cargo deps inspector
    'ms-python.python',                 # Python LSP (pulls Pylance + debugpy)
    'charliermarsh.ruff'                # Ruff linter/formatter
)

$codeCmd = $null
$codeOnPath = Get-Command code -ErrorAction SilentlyContinue
if ($codeOnPath) {
    $codeCmd = $codeOnPath.Source
} else {
    $candidates = @(
        "$env:LOCALAPPDATA\Programs\Microsoft VS Code\bin\code.cmd",
        "$env:ProgramFiles\Microsoft VS Code\bin\code.cmd"
    )
    foreach ($c in $candidates) {
        if (Test-Path $c) { $codeCmd = $c; break }
    }
}

if ($codeCmd) {
    $installed = & $codeCmd --list-extensions 2>$null
    foreach ($ext in $codeExtensions) {
        if ($installed -contains $ext) {
            Write-Host "VS Code extension $ext already installed"
        } else {
            Write-Host "Installing VS Code extension: $ext"
            & $codeCmd --install-extension $ext --force | Out-Null
        }
    }
} else {
    Write-Host "VS Code CLI not found yet -- extensions will install on the next chezmoi apply."
}

# -- BurntToast PowerShell module ---------------------------------------
# notify.sh + toggle-dnd.sh both call BurntToast for Windows toast OSD.
# Lives in PowerShell Gallery, not winget. First-time install needs the
# NuGet provider bootstrapped + PSGallery trust + TLS 1.2 (older Windows
# PowerShell defaults to TLS 1.0 which PSGallery rejects).
if (-not (Get-Module -ListAvailable -Name BurntToast)) {
    Write-Host "Installing BurntToast PowerShell module..."
    try {
        [Net.ServicePointManager]::SecurityProtocol = `
            [Net.ServicePointManager]::SecurityProtocol -bor [Net.SecurityProtocolType]::Tls12
        if (-not (Get-PackageProvider -Name NuGet -ListAvailable -ErrorAction SilentlyContinue)) {
            Install-PackageProvider -Name NuGet -MinimumVersion 2.8.5.201 `
                -Force -Scope CurrentUser -Confirm:$false | Out-Null
        }
        if ((Get-PSRepository -Name PSGallery -ErrorAction SilentlyContinue).InstallationPolicy -ne 'Trusted') {
            Set-PSRepository -Name PSGallery -InstallationPolicy Trusted
        }
        Install-Module -Name BurntToast -Scope CurrentUser `
            -Force -AllowClobber -SkipPublisherCheck -Confirm:$false
    } catch {
        Write-Warning "BurntToast install failed: $_"
    }
} else {
    Write-Host "BurntToast already installed"
}

# -- Toast AppId registration --------------------------------------------
# Windows 11 will not brand toasts from an unpackaged Win32 caller (here:
# powershell.exe) by registry alone -- it also requires a Start Menu .lnk
# whose AppUserModelID property matches the AUMID. Without the shortcut,
# CreateToastNotifier(<AppId>) succeeds but the toast renders as the
# calling process ("PowerShell"). BurntToast's New-BTShortcut does the
# IPropertyStore P/Invoke to set the AUMID property on the .lnk.
#   docs: https://learn.microsoft.com/en-us/windows/win32/shell/enable-desktop-toast-with-appusermodelid
if (Get-Module -ListAvailable -Name BurntToast) {
    # AUMID convention: Publisher.Product. Bare "ClaudeCode" gets ignored by
    # WpnUserService's notifier registration scan in some Win11 builds.
    $appId = 'Anthropic.ClaudeCode'
    $displayName = 'Claude Code'
    $appKey = "HKCU:\Software\Classes\AppUserModelId\$appId"

    # Clean up the prior bare-name AUMID + its shortcut.
    $oldKey = 'HKCU:\Software\Classes\AppUserModelId\ClaudeCode'
    if (Test-Path $oldKey) { Remove-Item -Path $oldKey -Recurse -Force -EA SilentlyContinue }
    $oldLnk = Join-Path $env:APPDATA 'Microsoft\Windows\Start Menu\Programs\ClaudeCode.lnk'
    if (Test-Path $oldLnk) { Remove-Item -Force $oldLnk -EA SilentlyContinue }
    $logoPng = Join-Path $env:USERPROFILE '.claude\claude-logo.png'
    $logoIco = Join-Path $env:USERPROFILE '.claude\claude-logo.ico'

    # Convert PNG -> ICO once for the .lnk icon. Registry IconUri accepts
    # PNG, but .lnk IconLocation needs ICO for reliable rendering.
    if ((Test-Path $logoPng) -and (-not (Test-Path $logoIco) -or `
            (Get-Item $logoPng).LastWriteTime -gt (Get-Item $logoIco).LastWriteTime)) {
        try {
            Add-Type -AssemblyName System.Drawing
            $bmp = [System.Drawing.Bitmap]::FromFile($logoPng)
            $hicon = $bmp.GetHicon()
            $icon = [System.Drawing.Icon]::FromHandle($hicon)
            $fs = [System.IO.File]::Create($logoIco)
            $icon.Save($fs)
            $fs.Close(); $bmp.Dispose()
            Write-Host "Converted Claude logo PNG -> ICO"
        } catch {
            Write-Warning "PNG->ICO conversion failed: $_"
        }
    }

    # Registry side: display name + icon for Action Center grouping.
    if (-not (Test-Path $appKey)) { New-Item -Path $appKey -Force | Out-Null }
    Set-ItemProperty -Path $appKey -Name DisplayName -Value $displayName -Type String
    # ShowInSettings=1 -> WpnUserService surfaces the AUMID in Settings >
    # Notifications & actions. Required for branded toasts in Win11 22H2+.
    Set-ItemProperty -Path $appKey -Name ShowInSettings -Value 1 -Type DWord
    if (Test-Path $logoPng) {
        Set-ItemProperty -Path $appKey -Name IconUri -Value $logoPng -Type String
    }

    # Start Menu shortcut with AUMID embedded -- the missing piece for
    # branded toasts. Idempotent: New-BTShortcut overwrites if path exists.
    $startMenu = Join-Path $env:APPDATA 'Microsoft\Windows\Start Menu\Programs'
    $lnkPath = Join-Path $startMenu 'Claude Code.lnk'
    Import-Module BurntToast -ErrorAction SilentlyContinue
    try {
        $btParams = @{
            AppId = $appId
            DisplayName = $displayName
            ShortcutPath = $lnkPath
        }
        if (Test-Path $logoIco) { $btParams.IconPath = $logoIco }
        New-BTShortcut @btParams -ErrorAction Stop
        Write-Host "Created Start Menu shortcut for AUMID '$appId' at $lnkPath"
    } catch {
        Write-Warning "New-BTShortcut failed: $_"
    }

    # Force WpnUserService to re-scan the Start Menu so the new AUMID
    # registers as a notification source. Without this, the first toasts
    # after first install still render under PowerShell branding.
    try {
        $wpn = Get-Service | Where-Object { $_.Name -like 'WpnUserService_*' } | Select-Object -First 1
        if ($wpn) {
            Restart-Service -Name $wpn.Name -Force -ErrorAction SilentlyContinue
            Write-Host "Restarted $($wpn.Name) to refresh AUMID registry"
        }
    } catch {
        Write-Warning "WpnUserService restart failed: $_"
    }
}

# -- AutoHotkey DND startup shortcut -------------------------------------
# Drop a shortcut in shell:startup pointing AutoHotkey at the managed
# .ahk script so Win+Shift+D works after every login. Idempotent.
$ahkScript = Join-Path $env:APPDATA 'AutoHotkey\dnd-toggle.ahk'
$ahkExe = @(
    "$env:LOCALAPPDATA\Programs\AutoHotkey\v2\AutoHotkey64.exe",
    "$env:ProgramFiles\AutoHotkey\v2\AutoHotkey64.exe",
    "$env:ProgramFiles\AutoHotkey\AutoHotkey.exe"
) | Where-Object { Test-Path $_ } | Select-Object -First 1
$startupDir = [Environment]::GetFolderPath('Startup')
$lnkPath = Join-Path $startupDir 'ClaudeDND.lnk'

if ($ahkExe -and (Test-Path $ahkScript)) {
    $needsCreate = -not (Test-Path $lnkPath)
    if (-not $needsCreate) {
        $shell = New-Object -ComObject WScript.Shell
        $existing = $shell.CreateShortcut($lnkPath)
        if ($existing.TargetPath -ne $ahkExe -or $existing.Arguments -ne "`"$ahkScript`"") {
            $needsCreate = $true
        }
    }
    if ($needsCreate) {
        Write-Host "Creating DND startup shortcut at $lnkPath"
        $shell = New-Object -ComObject WScript.Shell
        $lnk = $shell.CreateShortcut($lnkPath)
        $lnk.TargetPath = $ahkExe
        $lnk.Arguments = "`"$ahkScript`""
        $lnk.WorkingDirectory = Split-Path $ahkScript
        $lnk.Description = 'Claude DND toggle (Win+Shift+D)'
        $lnk.Save()
    } else {
        Write-Host "DND startup shortcut up to date"
    }
    # Launch now if not already running so the keybind works in this session.
    $ahkRunning = Get-Process -Name AutoHotkey64,AutoHotkey -ErrorAction SilentlyContinue |
        Where-Object { $_.Path -eq $ahkExe }
    if (-not $ahkRunning) {
        Start-Process -FilePath $ahkExe -ArgumentList "`"$ahkScript`"" -WindowStyle Hidden
    }
} else {
    if (-not $ahkExe)    { Write-Host "AutoHotkey not found -- DND shortcut deferred until next chezmoi apply." }
    if (-not (Test-Path $ahkScript)) { Write-Host "DND .ahk script not yet placed -- skipping startup shortcut." }
}
{{- end -}}