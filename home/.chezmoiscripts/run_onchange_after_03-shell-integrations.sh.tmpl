{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -euo pipefail

# Add shell integrations to .bashrc (idempotent — skips if already present).
# Linux/WSL only — Windows Git Bash uses run_once_after_00-git-bash-profile.sh.tmpl,
# which omits mise/zoxide (those are Linux-side via mise).

# Markers default to fixed-string match (-F). Use add_line_re for markers
# that contain regex metacharacters used intentionally (e.g. `.*`).
add_line() {
    local marker="$1" line="$2"
    if ! grep -qF -- "$marker" "$HOME/.bashrc"; then
        echo "$line" >> "$HOME/.bashrc"
    fi
}

add_line_re() {
    local marker="$1" line="$2"
    if ! grep -qE -- "$marker" "$HOME/.bashrc"; then
        echo "$line" >> "$HOME/.bashrc"
    fi
}

add_line    'BASH_ENV'             'export BASH_ENV="$HOME/.config/bash/noninteractive.sh"'
add_line    'mise activate bash'   'eval "$(mise activate bash)"'
add_line    'starship init bash'   'eval "$(starship init bash)"'
add_line_re 'GOPATH.*bin'          'export PATH="$(go env GOPATH)/bin:$PATH"'
add_line    'jj util completion'   'source <(jj util completion bash)'
add_line    'NVM_DIR'              'export NVM_DIR="$HOME/.nvm"; [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"'
add_line    'alias k=kubectl'      'alias k=kubectl'

# SSH agent - persist across terminal windows within same login session.
# First terminal starts the agent; subsequent terminals reuse it.
# Passphrase is prompted once, then cached until logout/reboot.
add_line 'ssh-agent' '
# SSH agent (persistent across terminal windows)
SSH_ENV="$HOME/.ssh/agent.env"
start_ssh_agent() {
    eval "$(ssh-agent -s)" > /dev/null
    printf "export SSH_AUTH_SOCK=%s\nexport SSH_AGENT_PID=%s\n" "$SSH_AUTH_SOCK" "$SSH_AGENT_PID" > "$SSH_ENV"
    chmod 600 "$SSH_ENV"
}
if [[ -f "$SSH_ENV" ]]; then
    . "$SSH_ENV" > /dev/null
    kill -0 "$SSH_AGENT_PID" 2>/dev/null || start_ssh_agent
else
    start_ssh_agent
fi
ssh-add -l &>/dev/null || ssh-add 2>/dev/null'

# zoxide MUST be last — it hooks cd/precmd and breaks if anything redefines them after.
# Move it to the end if a previous run placed it in the wrong position.
if grep -qF 'zoxide init bash' "$HOME/.bashrc"; then
    sed -i '/zoxide init bash/d' "$HOME/.bashrc"
fi
echo 'eval "$(zoxide init bash)"' >> "$HOME/.bashrc"
{{- end -}}
