{{- if eq .chezmoi.os "windows" -}}
# Windows-only winget installer.
# chezmoi runs .ps1 natively on Windows via PowerShell — no [interpreters] needed.
# Body-wrapped so this file is a no-op on Linux/macOS.
$ErrorActionPreference = 'Continue'  # tolerate individual package failures

# Bootstrap dependencies (needed before mise can run)
$bootstrap = @(
    'Microsoft.PowerShell',             # Update to latest
    'Git.Git',                          # Git for Windows (provides Git Bash)
    'twpayne.chezmoi',                  # chezmoi itself (idempotent)
    'jdx.mise'                          # mise tool manager
)

# Cloud CLIs — installed via winget on both platforms for consistency
$cloudCLIs = @(
    'Amazon.AWSCLI',
    'Microsoft.AzureCLI',
    'Google.CloudSDK'
)

# Desktop apps — Windows-native equivalents of Linux snap/deb packages
$desktopApps = @(
    'Anthropic.Claude',                 # Claude Desktop (replaces .deb on Linux)
    'SlackTechnologies.Slack',
    'Spotify.Spotify',
    'Notion.Notion',
    'Discord.Discord',
    'Zoom.Zoom',
    'calibre.calibre'                    # e-reader (Calibre on both Windows and Linux)
)

$packages = $bootstrap + $cloudCLIs + $desktopApps

foreach ($pkg in $packages) {
    $installed = winget list --id $pkg --exact 2>$null | Select-String $pkg
    if (-not $installed) {
        Write-Host "Installing $pkg..."
        try {
            winget install --exact --id $pkg `
                --accept-package-agreements `
                --accept-source-agreements --silent
        } catch {
            Write-Warning "Failed to install ${pkg}: $_"
        }
    } else {
        Write-Host "$pkg already installed"
    }
}
{{- end -}}