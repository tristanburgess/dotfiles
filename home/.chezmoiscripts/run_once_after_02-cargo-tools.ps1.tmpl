{{- if eq .chezmoi.os "windows" -}}
# Windows-only cargo installs.
# Runs after winget (which installs Rustup). Installs the default stable
# toolchain if absent, then builds tools that have no winget package.
$ErrorActionPreference = 'Stop'

# Ensure stable toolchain exists (winget only installs rustup itself)
& rustup toolchain install stable 2>$null

$tools = @(
    'difftastic'    # structural diff — used by jj
)

foreach ($tool in $tools) {
    $bin = $tool
    if ($tool -eq 'difftastic') { $bin = 'difft' }

    if (Get-Command $bin -ErrorAction SilentlyContinue) {
        Write-Host "$tool already installed"
    } else {
        Write-Host "Installing $tool via cargo..."
        try {
            & cargo install $tool
        } catch {
            Write-Warning "Failed to install ${tool}: $_"
        }
    }
}
{{- end -}}
