{{- if eq .chezmoi.os "windows" -}}
# Windows-only Rust toolchain setup + pre-built tool binaries.
$ErrorActionPreference = 'Continue'

# MSVC build tools are required for linking Rust projects (like energybeam).
# rustup only installs the compiler, not the linker/headers.
$installed = winget list --id Microsoft.VisualStudio.2022.BuildTools --exact 2>$null |
    Select-String 'Microsoft.VisualStudio.2022.BuildTools'
if (-not $installed) {
    Write-Host "Installing Visual Studio Build Tools (C++ workload)..."
    winget install --exact --id Microsoft.VisualStudio.2022.BuildTools `
        --accept-package-agreements --accept-source-agreements --silent `
        --override "--wait --passive --add Microsoft.VisualStudio.Workload.VCTools --includeRecommended"
} else {
    Write-Host "Visual Studio Build Tools already installed"
}

# Ensure stable toolchain exists (winget only installs rustup itself).
& rustup toolchain install stable 2>&1 | Out-Host

# difftastic: download pre-built binary instead of cargo install.
# cargo install builds in %TEMP% which Smart App Control (Win11 default)
# blocks for unsigned executables (os error 4551).
if (-not (Get-Command difft -ErrorAction SilentlyContinue)) {
    Write-Host "Installing difftastic (pre-built binary)..."
    $arch = 'x86_64-pc-windows-msvc'
    $release = Invoke-RestMethod 'https://api.github.com/repos/Wilfred/difftastic/releases/latest'
    $asset = $release.assets | Where-Object { $_.name -match $arch -and $_.name -match '\.zip$' } | Select-Object -First 1
    if ($asset) {
        $zip = "$env:TEMP\difft.zip"
        $extract = "$env:TEMP\difft-extract"
        try {
            Invoke-WebRequest -Uri $asset.browser_download_url -OutFile $zip -UseBasicParsing
            Expand-Archive -Path $zip -DestinationPath $extract -Force
            $difft = Get-ChildItem "$extract\difft.exe" -Recurse | Select-Object -First 1
            if ($difft) {
                $dest = "$env:USERPROFILE\.cargo\bin\difft.exe"
                Copy-Item $difft.FullName $dest -Force
                Write-Host "difftastic installed to $dest"
            }
        } catch {
            Write-Warning "Failed to install difftastic: $_"
        } finally {
            Remove-Item $zip, $extract -Recurse -Force -ErrorAction SilentlyContinue
        }
    } else {
        Write-Warning "Could not find difftastic release for $arch"
    }
} else {
    Write-Host "difftastic already installed" 
}
{{- end -}}
