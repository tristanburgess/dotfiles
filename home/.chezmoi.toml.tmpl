{{- $name := promptStringOnce . "name" "Full name" -}}
{{- $email := promptStringOnce . "email" "Email address" -}}
{{- $aiTools := promptMultichoiceOnce . "aiTools" "AI tools to install" (list "claude" "codex") (list "claude") -}}

{{- /* Detect total RAM for profile recommendation and num_ctx computation.
       Zero means detection unsupported on this platform (e.g. WSL). */ -}}
{{- $totalRamGiB := 0 -}}
{{- if eq .chezmoi.os "windows" -}}
{{-   $totalRamGiB = output "powershell" "-Command" "[math]::Round((Get-WmiObject Win32_OperatingSystem).TotalVisibleMemorySize/1MB,0)" | trim | atoi -}}
{{- else if eq .chezmoi.os "linux" -}}
{{-   $totalRamGiB = output "bash" "-c" "awk '/MemTotal/{printf \"%d\", $2/1024/1024}' /proc/meminfo" | trim | atoi -}}
{{- end -}}

{{- /* Recommend profile based on total RAM.
       < 48 GB: lean (smart's prose lane is 31B at ~20 GiB; with 30%
                headroom on 32 GB only ~4K ctx remains, too tight for
                daily use).
       >= 48 GB: smart (full 32K ctx achievable; quality wins justified).
       User can still pick smart explicitly on 32 GB by overriding the
       prompt — they'll just get a small ctx. */ -}}
{{- $recommendedProfile := "lean" -}}
{{- if ge $totalRamGiB 48 -}}{{- $recommendedProfile = "smart" -}}{{- end -}}

{{- /* Single source of truth for model names referenced across the
       routing stack. Bumping a model here propagates to:
         - run_onchange_after_07-llama-cpp-bootstrap.sh.tmpl (presets.ini, models)
         - dot_claude-code-router/config.json.tmpl (provider model list, Router map)
         - dot_claude-code-router/router.js.tmpl (LOCAL_* / CLOUD_* constants)
       Exposed in .chezmoi data as .local.{code,prose,think,draft} and
       .cloud.{sonnet,opus,haiku}.

       Local lanes are picked by the localProfile flag below:
         lean     — qwen3:14b code + gemma3:12b prose + qwen3:8b think.
                    Fits on any 16+ GB machine with typical app load. Best for
                    32 GB machines where browsers and other apps stay open.
         fast     — gemma4:26b-a4b code + gemma4:e4b prose + qwen3.6:35b-a3b
                    think. MoE models; fastest token generation, needs 48+ GB.
         balanced — qwen3.6:35b-a3b code+think + gemma4:26b-a4b prose.
                    MoE at frontier-class quality, needs 48+ GB.
         smart    — qwen3.6:27b dense code+think + gemma4:31b dense prose.
                    Highest single-shot quality; needs Chrome closed on 32 GB,
                    comfortable on 48+ GB.

       Names are llama.cpp-friendly slugs (no colons, dashes only). They
       match GGUF filenames in /var/lib/llama.cpp/models/<name>.gguf and
       become the OpenAI API model id. Draft model is qwen3-0.6b for the
       qwen3-family lanes (vocab 151936 matches qwen3:14b/8b targets);
       gemma3 prose lane has no draft (different family). */ -}}
{{- $profilePrompt := "Local model profile (lean | fast | balanced | smart)" -}}
{{- if gt $totalRamGiB 0 -}}
{{-   $profilePrompt = printf "Local model profile [%d GB detected, recommended: %s] (lean=14B fits anywhere | smart/fast/balanced=27-35B need 48+ GB for usable ctx)" $totalRamGiB $recommendedProfile -}}
{{- end -}}
{{- $localProfile := promptStringOnce . "localProfile" $profilePrompt $recommendedProfile -}}
{{- $localCode := "" -}}
{{- $localProse := "" -}}
{{- $localThink := "" -}}
{{- $localDraft := "qwen3-0.6b-draft" -}}
{{- if eq $localProfile "lean" -}}
{{-   $localCode  = "qwen3-14b-q4km" -}}
{{-   $localProse = "gemma3-12b-it-q4km" -}}
{{-   $localThink = "qwen3-8b-q4km" -}}
{{- else if eq $localProfile "fast" -}}
{{-   $localCode  = "gemma4-26b-a4b-it-q4km" -}}
{{-   $localProse = "gemma4-e4b-it-q4km" -}}
{{-   $localThink = "qwen3.6-35b-a3b-q4km" -}}
{{- else if eq $localProfile "smart" -}}
{{-   $localCode  = "qwen3.6-27b-q4km" -}}
{{-   $localProse = "gemma4-31b-it-q4km" -}}
{{-   $localThink = "qwen3.6-27b-q4km" -}}
{{- else -}}
{{-   $localCode  = "qwen3.6-35b-a3b-q4km" -}}
{{-   $localProse = "gemma4-26b-a4b-it-q4km" -}}
{{-   $localThink = "qwen3.6-35b-a3b-q4km" -}}
{{- end -}}

{{- /* Compute safe context window from total RAM + profile.
     Formula: (total_ram - headroom - model_weights) * tokens_per_gib
     Headroom is per-profile (the user's implicit OS-overhead budget):
       lean  45% — apps stay open, browsers running. Always-fits profile.
       smart 30% — focused session, Chrome closed. User commits to
                   resource management when picking smart.
       fast/balanced 35% — MoE on 48+ GB, some app management expected.
     tokens_per_gib derived from KV cache rate per profile:
       lean  (14B dense):    ~0.25 MB/token = 4000 tokens/GiB
       smart (27B dense):    ~0.41 MB/token = 2400 tokens/GiB
       fast/balanced (MoE):  ~0.18 MB/token = 5600 tokens/GiB
     Result is capped [2048, 32768]. Bootstrap warns if < 4096.
     Zero totalRamGiB (detection failed) → fall back to 20000. */ -}}
{{- $localNumCtx := 20000 -}}
{{- if gt $totalRamGiB 0 -}}
{{-   $localWeightsGiB := 9 -}}
{{-   $tokensPerGiB := 4000 -}}
{{-   $headroomPct := 45 -}}
{{- /* smart's prose lane is gemma4:31b (~20 GiB), bigger than the
       27B code/think model. Use the largest as the constraint so none
       of the three lanes OOMs when its derived model loads. */ -}}
{{-   if eq $localProfile "smart" -}}
{{-     $localWeightsGiB = 20 -}}
{{-     $tokensPerGiB = 2400 -}}
{{-     $headroomPct = 30 -}}
{{-   else if or (eq $localProfile "fast") (eq $localProfile "balanced") -}}
{{-     $localWeightsGiB = 18 -}}
{{-     $tokensPerGiB = 5600 -}}
{{-     $headroomPct = 35 -}}
{{-   end -}}
{{-   $headroomGiB := div (mul $totalRamGiB $headroomPct) 100 -}}
{{-   $kvGiB := sub (sub $totalRamGiB $headroomGiB) $localWeightsGiB -}}
{{-   $computed := mul $kvGiB $tokensPerGiB -}}
{{-   $localNumCtx = max 2048 (min 32768 $computed) -}}
{{- end -}}
{{- $cloudSonnet := "claude-sonnet-4-6" -}}
{{- $cloudOpus := "claude-opus-4-7" -}}
{{- $cloudHaiku := "claude-haiku-4-5-20251001" -}}
{{- /* Tiered model routing via claude-code-router + Ollama (local) +
       Anthropic API (cloud). Set false to run Claude Code straight to
       Anthropic with no proxy. */ -}}
{{- $useCcr := promptBoolOnce . "useCcr" (printf "Enable tiered routing: local llama.cpp (%s code, %s prose, %s think) + cloud Sonnet/Opus via CCR" $localCode $localProse $localThink) true -}}
{{- /* Expose the Windows-host Ollama on LAN (TCP 11434, Private profile,
       LocalSubnet only). Use case: a second laptop on the same network
       points at this box's LAN IP for Ollama. Untrusted networks remain
       blocked because Windows tags those adapters Public. */ -}}
{{- $enableLocalLan := promptBoolOnce . "enableLocalLan" "Expose local llama-server on LAN (TCP 11434, Private profile, LocalSubnet only)" false -}}
{{- /* Bias for sonnet/opus borderline-classified requests:
       true  (default): borderline → local lane (cost bias)
       false:           borderline → cloud (quality bias)
       Trivial requests always go local; complex always go cloud (except
       thinking + small ctx → local think lane, thinking + long ctx → Opus). */ -}}
{{- $defaultLocal := promptBoolOnce . "defaultLocal" "Local-first bias for borderline sonnet/opus routing (true = lower spend, false = cloud bias)" true -}}
{{- /* Where small/medium-context thinking-field requests go:
       true  (default): all thinking → cloud Opus (quality bias; local 30B-class
                        thinking models underperform on real planning tasks)
       false:           thinking + ctx ≤ 60K → active profile's think lane,
                        thinking + ctx > 60K → cloud Opus
       Long-context thinking always escapes to cloud Opus regardless. */ -}}
{{- $cloudThinking := promptBoolOnce . "cloudThinking" "Route all thinking-field requests to cloud Opus (true = quality bias, false = use local think lane for small ctx)" true -}}
{{- /* Audit logging: include a truncated user-prompt snippet in each
       [router] log line. Off by default since journalctl is durable.
       Toggle via chezmoi.toml then `chezmoi apply` (re-renders the
       systemd unit + restarts the service via run_onchange). */ -}}
{{- $logPrompt := promptBoolOnce . "logPrompt" "Include user-prompt snippets in ccr router audit logs (CCR_LOG_PROMPT)" false -}}
{{- /* Cloud authentication mode:
       apikey  (default): route cloud-tier requests directly to api.anthropic.com
                          using ANTHROPIC_API_KEY from secrets.env.
       ccs-pro:           route cloud-tier requests through a local CCS/CLIProxy
                          daemon (127.0.0.1:8317) which injects your Claude.ai
                          Pro/Max OAuth token. No API key needed.
                          Requires: npm install -g @kaitranntt/ccs + ccs claude --auth
                          Not available on WSL (WSL uses Windows-host CCR instead). */ -}}
{{- $cloudAuth := promptStringOnce . "cloudAuth" "Cloud auth mode (apikey | ccs-pro)" "apikey" -}}
{{- /* Opus thinking effort: low | medium | high | xhigh. Drop to "high"
       or "medium" to reduce per-call cost. Templated into the
       anthropic-shim transformer; takes effect on chezmoi apply. */ -}}
{{- $cloudThinkingEffort := get . "cloudThinkingEffort" | default "xhigh" -}}
{{- /* Routing ctx thresholds — three tiers, ordered:
         trivialCtx  ≤  localPerfCtx  <  complexCtx

       trivialCtx (12000): Claude Code baseline ctx overhead is ~10K; below
         this a request is small enough that local handles it instantly.
         Sonnet/opus → local trivial lane. Hardcoded — tied to Claude Code
         protocol overhead, not user preference.

       localPerfCtx (20000, prompted): Soft ceiling for local routing.
         Above this, iGPU prefill bandwidth dominates (40-100s before
         first token on AMD 890M with 30B-MoE). Push haiku and sonnet/opus
         borderline to cloud regardless of defaultLocal. Tune to your
         hardware. -1 disables (only complexCtx will force cloud).

       complexCtx (60000): Hard capacity cap — qwen3 context windows top
         out near here, beyond it local can't fit the request at all.
         Always cloud. Hardcoded — tied to local model capability.

       Invariants: trivialCtx ≤ localPerfCtx ≤ complexCtx. Setting
       localPerfCtx below trivialCtx forces trivial requests cloud (most
       aggressive cloud bias); setting it above complexCtx is a no-op. */ -}}
{{- /* trivialCtx clamp: never exceed localNumCtx, otherwise smart-profile
       small-RAM machines route trivial sonnet/opus to a local model that
       can't fit the request. Hard ceiling stays at 12000 (the Claude Code
       baseline below which a request is unambiguously cheap). */ -}}
{{- $trivialCtx := min 12000 $localNumCtx -}}
{{- /* localPerfCtx = localNumCtx: local model capacity IS the routing ceiling.
       Override ~/.config/chezmoi/chezmoi.toml manually if you want a lower
       threshold (e.g. Vulkan KV cache gets slow past 16K). */ -}}
{{- $localPerfCtx := $localNumCtx -}}
{{- /* complexCtx: escalate to dedicated long-context cloud path above this.
       Grows with local capacity so we never cut off local at 60K when the
       model can hold more. Currently a no-op (localNumCtx capped at 32768)
       but forward-compatible if the cap is raised. */ -}}
{{- $complexCtx := max 60000 $localNumCtx -}}
{{- /* Subagent names sniffed from request system prompts purely for audit
       logging (subagent=<name> field on log lines). Does not affect
       routing decisions. Add new agents here as you adopt them. */ -}}
{{- $knownSubagents := list
    "cavecrew-investigator" "cavecrew-builder" "cavecrew-reviewer"
    "prose-craft:prose-review" "prose-craft:craft-review" "prose-craft:learn-review"
    "claude-code-guide" "statusline-setup"
    "general-purpose" "Explore" "Plan" -}}

{{- /* OS detection: derive isWSL from kernel.osrelease on Linux */ -}}
{{- $isWSL := false -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   $osr := .chezmoi.kernel.osrelease | default "" | lower -}}
{{-   if or (contains "microsoft" $osr) (contains "wsl" $osr) -}}
{{-     $isWSL = true -}}
{{-   end -}}
{{- end -}}

sourceDir = {{ .chezmoi.sourceDir | quote }}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    isWSL = {{ $isWSL }}
    isWindows = {{ eq .chezmoi.os "windows" }}
    isLinuxBaremetal = {{ and (eq .chezmoi.os "linux") (not $isWSL) }}
    aiTools = {{ $aiTools | toJson }}
    installClaude = {{ has "claude" $aiTools }}
    installCodex = {{ has "codex" $aiTools }}
    useCcr = {{ $useCcr }}
    enableLocalLan = {{ $enableLocalLan }}
    defaultLocal = {{ $defaultLocal }}
    cloudThinking = {{ $cloudThinking }}
    logPrompt = {{ $logPrompt }}
    localProfile = {{ $localProfile | quote }}
    cloudAuth = {{ $cloudAuth | quote }}
    cloudThinkingEffort = {{ $cloudThinkingEffort | quote }}
    totalRamGiB = {{ $totalRamGiB }}
    localNumCtx = {{ $localNumCtx }}

[data.routing]
    trivialCtx     = {{ $trivialCtx }}
    localPerfCtx   = {{ $localPerfCtx }}
    complexCtx     = {{ $complexCtx }}
    knownSubagents = {{ $knownSubagents | toJson }}

[data.local]
    # Friendly llama.cpp model names. Match GGUF filenames at
    # /var/lib/llama.cpp/models/<name>.gguf and the OpenAI-API model id
    # exposed by the llama-server router on :11434. Per-model context size
    # and spec-decode draft come from /var/lib/llama.cpp/presets.ini,
    # generated by run_onchange_after_07-llama-cpp-bootstrap.sh.tmpl from
    # localNumCtx + this profile's lane assignments.
    code  = {{ $localCode  | quote }}
    prose = {{ $localProse | quote }}
    think = {{ $localThink | quote }}
    draft = {{ $localDraft | quote }}

[data.cloud]
    sonnet = {{ $cloudSonnet | quote }}
    opus   = {{ $cloudOpus | quote }}
    haiku  = {{ $cloudHaiku | quote }}

[merge]
    command = "nvim"
    args = ["-d", "{{ "{{" }} .Destination {{ "}}" }}", "{{ "{{" }} .Source {{ "}}" }}", "{{ "{{" }} .Target {{ "}}" }}"]

# Cross-platform .sh interpreter binding. Required on both OSes for two
# reasons:
#   1. Windows: chezmoi otherwise fork/exec's .sh files and Windows rejects
#      with "%1 is not a valid Win32 application".
#   2. Both OSes: chezmoi only strips a script extension from the target
#      filename when an interpreter is configured for it. We rely on this
#      stripping for `modify_settings.json.sh.tmpl` to resolve to target
#      `settings.json` (not `settings.json.sh`). Configuring [interpreters.sh]
#      on Linux too is what fixes the long-running cross-platform regression
#      where the file landed at `~/.claude/settings.json.sh` on Linux and
#      `~/.claude/settings` on Windows (the latter from a since-removed
#      [interpreters.json] block that stripped the wrong extension).
[interpreters.sh]
    command = {{ if eq .chezmoi.os "windows" }}'C:/Program Files/Git/bin/bash.exe'{{ else }}'/bin/bash'{{ end }}
